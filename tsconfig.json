{
    "compilerOptions": {
        "target": "es2020",
        "module": "commonjs",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true
    },
    "include": [
        "scripts/**/*.ts",
        "services/**/*.ts"
    ],
    "exclude": [
        "legacy",
        "node_modules"
    ]
}
