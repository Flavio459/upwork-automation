{
  "scripts": {
    "delegate:antigravity": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/delegate-antigravity.ps1",
    "antigravity:run-next": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/antigravity-run-next.ps1",
    "antigravity:review": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/antigravity-review-task.ps1",
    "antigravity:recover": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/antigravity-recover-task.ps1",
    "antigravity:requeue": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/antigravity-requeue-task.ps1",
    "antigravity:orchestrate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/antigravity-orchestrator.ps1",
    "antigravity:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/antigravity-status.ps1",
    "antigravity:audit:daily": "ts-node -T scripts/antigravity-daily-audit.ts",
    "antigravity:audit:register": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/register-antigravity-daily-audit-task.ps1",
    "antigravity:audit:unregister": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/unregister-antigravity-daily-audit-task.ps1",
    "antigravity:shadow:enqueue": "ts-node -T scripts/antigravity-shadow.ts enqueue-next",
    "antigravity:shadow:status": "ts-node -T scripts/antigravity-shadow.ts project-status",
    "antigravity:register": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/register-antigravity-orchestrator-task.ps1",
    "antigravity:unregister": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/unregister-antigravity-orchestrator-task.ps1",
    "handoff:refresh": "ts-node -T scripts/build-runtime-handoff.ts",
    "login": "ts-node -T scripts/login.ts",
    "research": "ts-node -T scripts/research.ts",
    "research:headless": "set UPWORK_RESEARCH_HEADLESS=true&& ts-node -T scripts/research.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/dotenv": "^6.1.1",
    "bullmq": "^5.73.0",
    "dotenv": "^17.2.3",
    "ioredis": "^5.10.1",
    "playwright": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/sqlite3": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
